      "presentation": {
        "reveal": "always",
        "panel": "new",
        "focus": true,
        "clear": true
      },
      "problemMatcher": [],
      "detail": "Runs the most recent /brain Phase 0 launch script"
    },
    {
      "label": "Tail Live Log",
      "type": "shell",
      "command": "tail -f \"${workspaceFolder}/.claude/orchestra/live.log\"",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false,
        "clear": true
      },
      "isBackground": true,
      "problemMatcher": [],
      "detail": "Follow the active orchestra pipeline stage log"
    }
  ]
}